---
import type { Profile } from '../types';

interface Props {
  profile: Profile;
}

const { profile } = Astro.props;

const categoryIcons: Record<string, string> = {
  'Frontend': '🎨',
  'Backend': '⚙️',
  'Infrastructure': '🏗️',
  'AI / LLM': '🤖',
  'DevOps': '🔄',
};
---

<section id="skills" class="py-24 px-6 bg-[#F0F0F0]/50">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl font-bold font-['Inter'] mb-4 animate-on-scroll">{profile.ui.sections.skills}</h2>
    <div class="w-16 h-1 bg-gradient-to-r from-[#6366F1] to-[#8B5CF6] rounded-full mb-12 animate-on-scroll"></div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {Object.entries(profile.skills).map(([category, skills]) => (
        <div class="group bg-white rounded-2xl p-6 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300 animate-on-scroll">
          <div class="flex items-center gap-3 mb-4">
            <span class="text-2xl">{categoryIcons[category] || '📦'}</span>
            <h3 class="text-lg font-bold font-['Inter']">{category}</h3>
          </div>
          <div class="flex flex-wrap gap-2">
            {skills.map((skill: string) => (
              <span class="jp-wrap px-3 py-1 text-sm bg-[#6366F1]/5 text-[#6366F1] rounded-lg border border-[#6366F1]/10 group-hover:border-[#6366F1]/30 transition-colors duration-300">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
