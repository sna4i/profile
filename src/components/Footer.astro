---
import type { Profile } from '../types';

interface Props {
  profile: Profile;
}

const { profile } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="py-8 px-6 text-center">
  <p class="text-sm text-gray-400">
    &copy; {year} {profile.name}. {profile.ui.footer}
  </p>
</footer>
