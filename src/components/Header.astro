---
import type { Locale, Profile } from '../types';

interface Props {
  profile: Profile;
  locale: Locale;
}

const { profile, locale } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const navItems = [
  { label: profile.ui.sections.about, href: '#about' },
  { label: profile.ui.sections.skills, href: '#skills' },
  { label: profile.ui.sections.projects, href: '#projects' },
  { label: profile.ui.sections.links, href: '#links' },
];

const localeOptions: { locale: Locale; label: string; href: string; aria: string }[] = [
  { locale: 'ja', label: 'JA', href: `${base}/`, aria: '日本語に切り替え' },
  { locale: 'en', label: 'EN', href: `${base}/en/`, aria: 'Switch to English' },
];
---

<header id="header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-[#FAFAFA]/80 backdrop-blur-md">
  <nav class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href={locale === 'ja' ? `${base}/` : `${base}/en/`} class="text-xl font-bold font-['Inter,monospace'] bg-gradient-to-r from-[#6366F1] to-[#8B5CF6] bg-clip-text text-transparent">
      &lt;S/&gt;
    </a>
    <div class="hidden md:flex items-center gap-6">
      <ul class="flex gap-8">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="text-sm font-medium text-gray-500 hover:text-[#6366F1] transition-colors duration-200"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
      <div role="group" aria-label="Language" class="inline-flex items-stretch border border-[#6366F1]/40 rounded-full overflow-hidden text-xs font-semibold tracking-widest divide-x divide-[#6366F1]/30 bg-white/60">
        {localeOptions.map((opt) => (
          opt.locale === locale ? (
            <span
              aria-current="page"
              class="px-3 py-1 bg-[#6366F1] text-white"
            >
              {opt.label}
            </span>
          ) : (
            <a
              href={opt.href}
              aria-label={opt.aria}
              class="px-3 py-1 text-[#6366F1] hover:bg-[#6366F1]/10 transition-colors duration-200"
            >
              {opt.label}
            </a>
          )
        ))}
      </div>
    </div>
    <button id="menu-toggle" class="md:hidden p-2 text-gray-500 hover:text-[#6366F1]" aria-label="Menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>
  <div id="mobile-menu" class="hidden md:hidden px-6 pb-4">
    <ul class="flex flex-col gap-4">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="text-sm font-medium text-gray-500 hover:text-[#6366F1] transition-colors duration-200"
          >
            {item.label}
          </a>
        </li>
      ))}
      <li>
        <div role="group" aria-label="Language" class="inline-flex items-stretch border border-[#6366F1]/40 rounded-full overflow-hidden text-xs font-semibold tracking-widest divide-x divide-[#6366F1]/30 bg-white/60">
          {localeOptions.map((opt) => (
            opt.locale === locale ? (
              <span
                aria-current="page"
                class="px-3 py-1 bg-[#6366F1] text-white"
              >
                {opt.label}
              </span>
            ) : (
              <a
                href={opt.href}
                aria-label={opt.aria}
                class="px-3 py-1 text-[#6366F1] hover:bg-[#6366F1]/10 transition-colors duration-200"
              >
                {opt.label}
              </a>
            )
          ))}
        </div>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  menu?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => menu?.classList.add('hidden'));
  });
</script>
