---
import type { Profile } from '../types';

interface Props {
  profile: Profile;
}

const { profile } = Astro.props;
---

<section id="projects" class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl font-bold font-['Inter'] mb-4 animate-on-scroll">{profile.ui.sections.projects}</h2>
    <div class="w-16 h-1 bg-gradient-to-r from-[#6366F1] to-[#8B5CF6] rounded-full mb-12 animate-on-scroll"></div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {profile.projects.map((project) => (
        <div class="group bg-white rounded-2xl p-6 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300 animate-on-scroll relative overflow-hidden">
          <!-- Accent top border -->
          <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-[#6366F1] to-[#8B5CF6] opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

          <h3 class="text-lg font-bold font-['Inter'] mb-3 group-hover:text-[#6366F1] transition-colors duration-200">
            {project.name}
          </h3>
          <p class="jp-wrap text-sm text-gray-500 leading-relaxed mb-4">
            {project.description}
          </p>
          <div class="flex flex-wrap gap-2">
            {project.tags.map((tag: string) => (
              <span class="px-2 py-0.5 text-xs font-medium text-[#34D399] bg-[#34D399]/10 rounded-md">
                {tag}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
